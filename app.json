{
  "expo": {
    "name": "Homenet Messenger",
    "slug": "homenet-messenger",
    "scheme": "homenet",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "./modules/hm-e2ee/plugin/withHmE2ee",
      "./modules/hm-native-calls/plugin/withHmNativeCalls",
      "@livekit/react-native-expo-plugin",
      "@config-plugins/react-native-webrtc",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.homenet.messenger"
    },
    "android": {
      "package": "com.homenet.messenger",
      "permissions": ["POST_NOTIFICATIONS"]
    },
    "extra": {
      "apiBaseUrl": "http://localhost:4000",
      "allowInsecureCryptoStub": false
    }
  }
}
